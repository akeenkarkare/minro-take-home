# --- Anthropic (required) ---
# Used by the AI chat layer and the LLM-driven inference normalizer.
# Only per-person collected signals are sent to the LLM, never the original CSV.
ANTHROPIC_API_KEY=

# Model used for chat + inference. claude-sonnet-4-6 is the default.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- GitHub (recommended) ---
# Personal access token (classic, no scopes needed for public reads).
# Without this, GitHub API calls are rate-limited to 60/hr and 2k people will
# not finish enriching. With it, the limit is 5,000/hr.
GITHUB_TOKEN=

# --- Public search (optional, recommended) ---
# Brave Search API key. Free tier: 2,000 queries/month, 1 qps.
# Used to discover personal websites, X/Twitter handles, etc.
# If unset, the pipeline falls back to DuckDuckGo HTML scraping.
BRAVE_SEARCH_API_KEY=

# --- Postgres ---
POSTGRES_USER=minro
POSTGRES_PASSWORD=minro
POSTGRES_DB=minro
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Service ports ---
API_PORT=8000
WEB_PORT=3000

# --- Web ---
# URL the browser uses to hit the API. For docker-compose on localhost the
# default is correct. Change for deployments behind a reverse proxy.
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Pipeline tuning ---
# Per-source concurrency caps — tune if you start hitting rate limits.
GITHUB_CONCURRENCY=5
WEB_FETCH_CONCURRENCY=10
SEARCH_CONCURRENCY=2

# Per-host request timeout (seconds).
HTTP_TIMEOUT=10
